#![recursion_limit = "2048"]

use bevy::prelude::*;

mod components;
mod entities;
mod game;
mod map;
mod spawnable;
mod tile_loader;

use {components::TileType, game::Game};

#[derive(Resource)]
struct GameResource {
  game: Game
}

#[derive(Component)]
struct MapTile {
  x: usize,
  y: usize,
  z: usize
}

#[derive(Component)]
struct PlayerSprite;

#[derive(Component)]
struct CurrentLevelIndicator;

fn main() {
  App::new()
    .add_plugins(DefaultPlugins.set(WindowPlugin {
      primary_window: Some(Window {
        title: "TRL - Terminal Roguelike".to_string(),
        resolution: (1280, 720).into(),
        ..default()
      }),
      ..default()
    }))
    .insert_resource(ClearColor(Color::srgb(0.05, 0.05, 0.1)))
    .add_systems(Startup, setup)
    .add_systems(Update, render_frame)
    .run();
}

fn setup(mut commands: Commands) {
  commands.spawn(Camera2d);

  let game = Game::new();
  let tiles = game.current_level_tiles();
  let current_z = game.current_z;

  for y in 0..game.map.height {
    for x in 0..game.map.width {
      let tile = &tiles[y][x];
      let color = match tile.tile_type {
        TileType::Floor => Color::srgb(0.3, 0.25, 0.2),
        TileType::Wall => Color::srgb(0.5, 0.5, 0.5),
        TileType::StairsDown => Color::srgb(0.8, 0.6, 0.2),
        TileType::StairsUp => Color::srgb(0.2, 0.8, 0.6),
        TileType::Water => Color::srgb(0.2, 0.4, 0.8),
        TileType::Grass => Color::srgb(0.2, 0.7, 0.2),
        TileType::Sand => Color::srgb(0.9, 0.8, 0.5)
      };

      commands.spawn((
        Sprite { color, custom_size: Some(Vec2::new(12.0, 12.0)), ..default() },
        Transform::from_xyz(x as f32 * 12.0 - 480.0, y as f32 * -12.0 + 144.0, 0.0),
        MapTile { x, y, z: current_z }
      ));
    }
  }

  let player_pos = game.state.player.pos;
  commands.spawn((
    Sprite {
      color: Color::srgb(1.0, 1.0, 1.0),
      custom_size: Some(Vec2::new(10.0, 10.0)),
      ..default()
    },
    Transform::from_xyz(
      player_pos.x as f32 * 12.0 - 480.0,
      player_pos.y as f32 * -12.0 + 144.0,
      1.0
    ),
    PlayerSprite
  ));

  commands.insert_resource(GameResource { game });
}

fn render_frame() {
  // Empty system to ensure window redraws
}

